#!/usr/bin/env python3
"""Query DeepWiki API via JSON-RPC over HTTP.

Usage:
  deepwiki structure <owner/repo>
  deepwiki contents  <owner/repo>
  deepwiki ask       <owner/repo> "<question>"

Aliases: s=structure, c=contents, a=ask

Environment:
  DEEPWIKI_ENDPOINT   Override API URL (default: https://mcp.deepwiki.com/mcp)
"""
from __future__ import annotations

import json
import os
import sys
import urllib.error
import urllib.request

ENDPOINT = os.environ.get("DEEPWIKI_ENDPOINT", "https://mcp.deepwiki.com/mcp")


def call_tool(tool_name: str, arguments: dict) -> None:
    """Call a DeepWiki MCP tool and print text content to stdout."""
    body = json.dumps({
        "jsonrpc": "2.0",
        "id": 1,
        "method": "tools/call",
        "params": {"name": tool_name, "arguments": arguments},
    }).encode("utf-8")

    headers = {
        "Content-Type": "application/json",
        "Accept": "application/json, text/event-stream",
    }
    raw: str | None = None
    last_exc: Exception | None = None

    for try_direct in (False, True):
        try:
            req = urllib.request.Request(ENDPOINT, data=body, headers=headers, method="POST")
            if try_direct:
                opener = urllib.request.build_opener(urllib.request.ProxyHandler({}))
                resp = opener.open(req, timeout=30)
            else:
                resp = urllib.request.urlopen(req, timeout=30)
            raw = resp.read().decode("utf-8")
            break
        except (urllib.error.URLError, OSError) as exc:
            last_exc = exc
            continue

    if raw is None:
        print(f"Error: DeepWiki unreachable — {last_exc}", file=sys.stderr)
        sys.exit(1)

    # Parse SSE: extract the first complete JSON payload from data: lines
    for line in raw.splitlines():
        if line.startswith("data: "):
            try:
                payload = json.loads(line[6:])
            except json.JSONDecodeError:
                continue

            if "error" in payload:
                msg = payload["error"].get("message", "unknown error")
                print(f"Error: {msg}", file=sys.stderr)
                sys.exit(1)

            for item in payload.get("result", {}).get("content", []):
                if item.get("type") == "text":
                    print(item["text"])
            return

    # No SSE envelope found; try parsing raw response as JSON
    try:
        payload = json.loads(raw)
    except json.JSONDecodeError:
        print("Error: unexpected response format from DeepWiki", file=sys.stderr)
        sys.exit(1)

    if "error" in payload:
        msg = payload["error"].get("message", "unknown error")
        print(f"Error: {msg}", file=sys.stderr)
        sys.exit(1)

    for item in payload.get("result", {}).get("content", []):
        if item.get("type") == "text":
            print(item["text"])


def main() -> None:
    if len(sys.argv) < 2 or sys.argv[1] in ("-h", "--help"):
        print(__doc__.strip())
        sys.exit(0 if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help") else 1)

    cmd = sys.argv[1]

    if len(sys.argv) < 3:
        print("Error: <owner/repo> required", file=sys.stderr)
        sys.exit(1)
    repo = sys.argv[2]

    if cmd in ("structure", "s"):
        call_tool("read_wiki_structure", {"repoName": repo})
    elif cmd in ("contents", "c"):
        call_tool("read_wiki_contents", {"repoName": repo})
    elif cmd in ("ask", "a"):
        if len(sys.argv) < 4:
            print("Error: question required", file=sys.stderr)
            sys.exit(1)
        call_tool("ask_question", {"repoName": repo, "question": sys.argv[3]})
    else:
        print(f"Unknown command: {cmd}", file=sys.stderr)
        sys.exit(1)


if __name__ == "__main__":
    main()
